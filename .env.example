# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WalletConnect (Reown AppKit)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# 1Click (Defuse cross-chain swaps)
ONE_CLICK_BASE_URL=https://1click.chaindefuser.com
ONE_CLICK_JWT=your-oneclick-jwt

# Resend (email notifications — free tier: 3,000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Supabase Custom SMTP (optional — configure in Supabase dashboard for branded auth emails)
# Host: smtp.resend.com | Port: 465 | User: resend | Password: your RESEND_API_KEY
# This makes Supabase auth emails (verification, password reset) go through Resend

# Open Exchange Rates (free tier: 1,000 requests/month — hourly refresh = ~720/month)
OPEN_EXCHANGE_RATES_APP_ID=your-open-exchange-rates-app-id

# Cron (Vercel sends this automatically for cron jobs)
CRON_SECRET=your-cron-secret

# Coinbase Offramp (CDP — Coinbase Developer Platform, from portal.cdp.coinbase.com)
COINBASE_CDP_API_KEY=your-cdp-api-key
COINBASE_CDP_API_SECRET="-----BEGIN EC PRIVATE KEY-----\nyour-cdp-private-key\n-----END EC PRIVATE KEY-----"

# Onramper (global offramp widget — 190+ countries, from onramper.com dashboard)
NEXT_PUBLIC_ONRAMPER_API_KEY=your-onramper-api-key
